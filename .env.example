OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
PORT=8806

# Database: for local dev use localhost:5433, Docker Compose overrides this
# to postgresql://postgres:postgres@postgres:5432/newsbot automatically
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/newsbot

# Auth
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long
AUTH_ADMIN_EMAIL=admin@local.dev
AUTH_ADMIN_PASSWORD=changeme

# CORS: comma-separated list of allowed origins
# Local dev:   http://localhost:3306
# Production:  https://your-domain.com
TRUSTED_ORIGINS=http://localhost:3306

# Pipeline API key (min 16 chars)
PIPELINE_API_KEY=your-pipeline-api-key-here
