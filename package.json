{
  "name": "news-bot",
  "private": true,
  "scripts": {
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build": "pnpm -r build",
    "db:migrate": "pnpm --filter backend db:migrate",
    "db:generate": "pnpm --filter backend db:generate",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build -d",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:deploy": "docker compose -f docker-compose.prod.yml up --build -d",
    "docker:deploy:down": "docker compose -f docker-compose.prod.yml down",
    "pipeline": "export $(grep PIPELINE_API_KEY .env) && pnpm --filter backend pipeline",
    "purge": "pnpm --filter backend purge"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  }
}
