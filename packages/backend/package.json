{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "pipeline": "curl -s -X POST -H \"x-api-key: $PIPELINE_API_KEY\" http://localhost:8806/api/pipeline/run | node -e \"process.stdin.resume(); let d=''; process.stdin.on('data',c=>d+=c); process.stdin.on('end',()=>{const r=JSON.parse(d); console.log('Report:', r.reportKey, '| Articles:', r.articleCount)})\"",
    "purge": "tsx src/scripts/purge.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@mozilla/readability": "^0.6.0",
    "@prisma/client": "^6",
    "better-auth": "^1.5.5",
    "dotenv": "^16",
    "fastify": "^5",
    "jsdom": "^29.0.0",
    "node-cron": "^3",
    "openai": "^4",
    "rss-parser": "^3",
    "toml": "^3",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.0",
    "@types/node": "^20",
    "@types/node-cron": "^3",
    "prisma": "^6",
    "tsx": "^4",
    "typescript": "^5"
  }
}
